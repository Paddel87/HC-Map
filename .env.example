# HC-Map environment variables.
# Copy to .env (gitignored) and adjust for your local setup.
#
# Production uses the same names; secrets MUST be different in production.

# --- Postgres / PostGIS ---------------------------------------------------
HCMAP_DB_USER=hcmap
HCMAP_DB_PASSWORD=hcmap
HCMAP_DB_NAME=hcmap

# --- Backend (FastAPI) ----------------------------------------------------
# environment: development | test | production
HCMAP_ENVIRONMENT=development
# log_level: DEBUG | INFO | WARNING | ERROR
HCMAP_LOG_LEVEL=INFO
# Async SQLAlchemy DSN. Container-internal hostname is "db".
HCMAP_DATABASE_URL=postgresql+asyncpg://hcmap:hcmap@db:5432/hcmap

# --- Auth / Session (M2) -------------------------------------------------
# Required: at least 32 characters, kept secret; rotates session validity.
HCMAP_SECRET_KEY=change-me-in-production-32-bytes-minimum-aaaaa
# In production keep cookie_secure=true (HTTPS-only). Set to false for local
# HTTP dev. Cookies: hcmap_session (HttpOnly, JWT) + hcmap_csrf (readable).
HCMAP_COOKIE_SECURE=true
# Session lifetime in seconds (default 7 days = 604800).
HCMAP_COOKIE_LIFETIME_SECONDS=604800
# Argon2id parameters (defaults follow OWASP 2024 recommendation).
HCMAP_ARGON2_TIME_COST=2
HCMAP_ARGON2_MEMORY_COST=19456
HCMAP_ARGON2_PARALLELISM=1

# --- Bootstrap (one-off) -------------------------------------------------
# Optional defaults for `python -m scripts.bootstrap_admin`. Email and
# password can also be passed as CLI flags.
# HCMAP_BOOTSTRAP_EMAIL=admin@example.com
# HCMAP_BOOTSTRAP_PASSWORD=change-me-12-chars-or-more
# HCMAP_BOOTSTRAP_NAME=Admin

# --- Future variables (added with their respective milestones) -----------
# HCMAP_MAPTILER_KEY=                # M6 — MapTiler tile/geocoding key
# HCMAP_SMTP_URL=                    # before M11 — password reset mail

# HC-Map environment variables.
# Copy to .env (gitignored) and adjust for your local setup.
#
# Production uses the same names; secrets MUST be different in production.

# --- Postgres / PostGIS ---------------------------------------------------
HCMAP_DB_USER=hcmap
HCMAP_DB_PASSWORD=hcmap
HCMAP_DB_NAME=hcmap

# --- Backend (FastAPI) ----------------------------------------------------
# environment: development | test | production
HCMAP_ENVIRONMENT=development
# log_level: DEBUG | INFO | WARNING | ERROR
HCMAP_LOG_LEVEL=INFO
# Async SQLAlchemy DSN. Container-internal hostname is "db".
HCMAP_DATABASE_URL=postgresql+asyncpg://hcmap:hcmap@db:5432/hcmap

# --- Future variables (added with their respective milestones) -----------
# HCMAP_SECRET_KEY=                  # M2 — fastapi-users session secret
# HCMAP_MAPTILER_KEY=                # M6 — MapTiler tile/geocoding key
# HCMAP_SMTP_URL=                    # before M11 — password reset mail

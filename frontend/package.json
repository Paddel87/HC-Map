{
  "name": "hc-map-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "HC-Map frontend (Next.js App Router, TypeScript strict).",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "15.0.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "2.5.5"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.0.4",
    "eslint-config-prettier": "9.1.0",
    "postcss": "8.5.10",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22 <23"
  }
}
